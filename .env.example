# --- widget brick/partial cache (pgvector + local Ollama embeddings) ---
# Host port for the container's postgres (avoid clashes with a native postgres).
POSTGRES_HOST_PORT=5433
PGHOST=localhost
PGPORT=5433
PGUSER=intelligence
PGPASSWORD=intelligence
WIDGETCACHE_DB=widgetcache
DATABASE_URL=postgresql://intelligence:intelligence@localhost:5433/widgetcache
OLLAMA_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text
