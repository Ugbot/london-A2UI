OPENAI_API_KEY=your-api-key-here
AGENT_URL=http://localhost:8000

# --- copilotkit:intelligence (optional local threads stack) ---
# COPILOTKIT_LICENSE_TOKEN=
# INTELLIGENCE_API_KEY=
# INTELLIGENCE_API_URL=http://localhost:4201
