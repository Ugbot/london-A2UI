{
  "name": "widget-composer",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "scripts": {
    "dev": "npm run dev:infra && concurrently \"npm run dev:collab\" \"next dev --turbopack\" --names collab,ui --prefix-colors magenta,blue --kill-others",
    "dev:debug": "LOG_LEVEL=debug npm run dev",
    "dev:ui": "next dev --turbopack",
    "dev:collab": "node scripts/collab-server.mjs",
    "build": "next build",
    "start": "next start",
    "dev:infra": "node scripts/copilotkit-dev-infra.mjs",
    "cache:smoke": "node --env-file=.env --import tsx scripts/cache-smoke.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
