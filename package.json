    "jspdf": "^4.2.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.561.0",
    "maplibre-gl": "^5.24.0",
    "next": "16.0.7",
    "pg": "^8.21.0",
    "pgvector": "^0.3.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.8.1",
    "sucrase": "^3.35.1",
